{
  "name": "terminalizer",
  "version": "0.12.0",
  "description": "Record your terminal and generate animated gif images or share a web player",
  "main": "dist/app.js",
  "type": "module",
  "author": "Mohammad Fares <faressoft.com@gmail.com>",
  "license": "MIT",
  "homepage": "https://www.terminalizer.com",
  "repository": {
    "type": "git",
    "url": "https://github.com/faressoft/terminalizer.git"
  },
  "bin": {
    "terminalizer": "./dist/bin/app.js"
  },
  "scripts": {
    "dev": "NODE_ENV=development bunx webpack --watch --config webpack.config.cjs",
    "build": "bun run typecheck && NODE_ENV=production bunx webpack --progress --config webpack.config.cjs",
    "build:cli": "bun run typecheck && bun run tsc",
    "typecheck": "bun run tsc --noEmit",
    "lint": "bun run eslint . --config eslint.config.cjs",
    "start": "bun run bin/app.ts"
  },
  "keywords": [
    "terminal",
    "record",
    "capture",
    "tty",
    "shot",
    "bash",
    "powershell",
    "gif",
    "animated",
    "generate",
    "theme",
    "colors",
    "font",
    "repeat",
    "command-line",
    "shell",
    "zsh",
    "bash-profile",
    "render",
    "pty"
  ],
  "dependencies": {
    "@homebridge/node-pty-prebuilt-multiarch": "^0.13.1",
    "@types/xterm": "^3.0.0",
    "@xterm/xterm": "^6.0.0",
    "async": "^3.2.6",
    "async-promises": "^0.2.2",
    "axios": "^1.15.0",
    "chalk": "^5.6.2",
    "death": "^1.1.0",
    "deepmerge": "^4.3.1",
    "electron": "^41.2.0",
    "fs-extra": "^11.3.4",
    "gif-encoder": "^0.7.2",
    "inquirer": "^13.4.1",
    "js-yaml": "^4.1.1",
    "lodash": "^4.18.1",
    "performance-now": "^2.1.0",
    "pngjs": "^7.0.0",
    "progress": "^2.0.3",
    "require-dir": "^1.1.0",
    "string-argv": "0.3.2",
    "tmp": "^0.2.5",
    "uuid": "^13.0.0",
    "yargs": "^18.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/async": "^3.2.25",
    "@types/deepmerge": "^2.2.3",
    "@types/fs-extra": "^11.0.4",
    "@types/js-yaml": "^4.0.9",
    "@types/lodash": "^4.17.0",
    "@types/node": "^22.0.0",
    "@types/progress": "^2.0.7",
    "@types/tmp": "^0.2.6",
    "@types/yargs": "^17.0.35",
    "@typescript-eslint/eslint-plugin": "^8.58.1",
    "@typescript-eslint/parser": "^8.58.1",
    "ajv": "^8.18.0",
    "bun-types": "^1.3.12",
    "clean-webpack-plugin": "^4.0.0",
    "css-loader": "^7.1.4",
    "eslint": "^10.2.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "jquery": "^4.0.0",
    "mini-css-extract-plugin": "^2.10.2",
    "terminalizer-player": "^0.4.1",
    "typescript": "^6.0.2",
    "typescript-eslint": "^8.58.1",
    "webpack": "^5.106.1",
    "webpack-cli": "^7.0.2",
    "xterm": "^5.3.0"
  }
}